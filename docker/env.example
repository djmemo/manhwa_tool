# ═══════════════════════════════════════════════════════════════════════════════
#  Manhwa Tool — Variables d'environnement Docker
#  Copiez ce fichier en .env et adaptez les valeurs.
#
#  Usage :
#    docker run --env-file .env -it manhwa-tool:latest
#    docker compose up          (docker-compose.yml charge .env automatiquement)
# ═══════════════════════════════════════════════════════════════════════════════

# Chemin racine des projets OsirisScan DANS le conteneur.
# Doit correspondre au point de montage du volume hôte.
# Exemple hôte Windows : -v "D:/OsirisScan:/data/osirisscan"
# Exemple hôte Linux   : -v "$HOME/OsirisScan:/data/osirisscan"
OSIRISSCAN_RACINE=/data/osirisscan

# Chemin vers le binaire Real-ESRGAN DANS le conteneur.
# Monter le dossier hôte en lecture seule :
#   -v "/chemin/local/realesrgan:/tools/realesrgan:ro"
ESRGAN_EXE_PATH=/tools/realesrgan/realesrgan-ncnn-vulkan

# Largeur de la bannière console (défaut : 80)
CONSOLE_LARGEUR=80

# ── Variables hôte pour docker-compose.yml ───────────────────────────────────
# Ces variables sont lues par docker-compose.yml pour les bind mounts.

# Chemin HÔTE vers le dossier OsirisScan (sera monté dans /data/osirisscan)
# Windows : OSIRISSCAN_HOST_PATH=D:/OsirisScan
# Linux   : OSIRISSCAN_HOST_PATH=/home/user/OsirisScan
OSIRISSCAN_HOST_PATH=./data

# Chemin HÔTE vers le dossier Real-ESRGAN (sera monté dans /tools/realesrgan)
# Laisser vide ou commenter si Real-ESRGAN non disponible
ESRGAN_HOST_PATH=
